@dataclass
class ScoredResult:
    session_id: str
    score: float
    question_preview: str
    summary: str | None
    project: str
    date: datetime
    topics: list[str]


@dataclass
class SessionKnowledge:
    summary: str | None
    user_requests: str | None
    completed_work: str | None
    topics: list[str]
    first_answer: str
    tool_counts: dict[str, int] | None = None
    all_answers: list[str] | None = None


# ─────────────────────────────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────────────────────────────

def derive_project(cwd: str) -> str:
    if not cwd:
        return "?"
    home = os.path.expanduser("~")
    path = cwd.replace(home, "~")
    parts = [p for p in path.rstrip("/").split("/") if p and p != "~"]
    return parts[-1][:16] if parts else "?"


def clean_preview(content: str, max_len: int = 100) -> str:
    if not content:
        return ""
    text = content.strip()
    # Strip XML-like tags
    text = re.sub(r"<[^>]+>.*?</[^>]+>", " ", text, flags=re.S)
    text = re.sub(r"<[^>]+>", " ", text)
    text = re.sub(r"^/\S+\s*", "", text.strip())
    text = re.sub(r"\s+", " ", text).strip()
    if len(text) > max_len:
        text = text[:max_len - 1].rstrip() + "…"
    return text


def ensure_table(conn):
    """Create session_embeddings_v2 table if it doesn't exist."""
    with conn.cursor() as cur:
        cur.execute("""
            CREATE TABLE IF NOT EXISTS claude_sessions.session_embeddings_v2 (
                id SERIAL PRIMARY KEY,
                session_id VARCHAR NOT NULL UNIQUE
                    REFERENCES claude_sessions.sessions(session_id) ON DELETE CASCADE,
                embedding vector(3072) NOT NULL,
                content_hash TEXT,
                model TEXT DEFAULT 'gemini-embedding-001',
                created_at TIMESTAMPTZ DEFAULT NOW()
            );
        """)
    conn.commit()


def ensure_index(conn):
    """No-op: 3072-dim vectors exceed pgvector's 2000-dim index limit.
    Sequential scan is fast enough for <10K rows."""
    pass


