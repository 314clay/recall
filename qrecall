# Google AI embedding
# ─────────────────────────────────────────────────────────────────────

def _get_google_api_key() -> str:
    """Get Google API key from env var or macOS Keychain."""
    key = os.environ.get("GOOGLE_API_KEY", "")
    if key:
        return key
    try:
        key = subprocess.check_output(
            ["security", "find-generic-password", "-s", "google-api-key", "-w"],
            text=True,
        ).strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        pass
    return key


def embed_texts(texts: list[str]) -> list[list[float]]:
    """Embed a batch of texts via Google AI gemini-embedding-001."""
    api_key = _get_google_api_key()
    if not api_key:
        print(f"No Google API key found. Set GOOGLE_API_KEY or add 'google-api-key' to Keychain.")
        sys.exit(1)

    # Avoid noisy "Both GOOGLE_API_KEY and GEMINI_API_KEY are set" warning
    os.environ.pop("GEMINI_API_KEY", None)
    os.environ["GOOGLE_API_KEY"] = api_key
    from google import genai

    client = genai.Client(api_key=api_key)
    results = []
    for text in texts:
        truncated = text[:10000]
        result = client.models.embed_content(
            model=EMBEDDING_MODEL,
            contents=truncated,
        )
        results.append(result.embeddings[0].values)
    return results


def embed_text(text: str) -> list[float]:
    return embed_texts([text])[0]


def vec_str(embedding: list[float]) -> str:
    return "[" + ",".join(str(f) for f in embedding) + "]"


# ─────────────────────────────────────────────────────────────────────
# Similarity strategies
# ─────────────────────────────────────────────────────────────────────

class SimilarityStrategy(ABC):
    """Swappable similarity backend."""

    @abstractmethod
    def find_similar(self, query: str, limit: int, since_days: int | None) -> list[ScoredResult]:
        ...


class MultimodalEmbeddingStrategy(SimilarityStrategy):
    """Vertex AI multimodalembedding@001 + pgvector cosine similarity."""

    def find_similar(self, query: str, limit: int, since_days: int | None) -> list[ScoredResult]:
        query_emb = embed_text(query)
        conn = get_conn()
        try:
            with conn.cursor(cursor_factory=psycopg2.extras.RealDictCursor) as cur:
                time_filter = ""
                params: dict = {
                    "vec": vec_str(query_emb),
                    "limit": limit,
                }
                if since_days:
                    time_filter = "AND s.start_time >= NOW() - INTERVAL '%(days)s days'"
                    # Use string interpolation for interval since parameterized won't work
                    time_filter = f"AND s.start_time >= NOW() - INTERVAL '{since_days} days'"

                cur.execute(f"""
                    SELECT
                        se.session_id,
                        1 - (se.embedding <=> %(vec)s::vector) AS similarity,
                        ss.summary,
                        ss.user_requests,
                        ss.topics,
                        s.cwd,
                        s.start_time,
                        fm.content AS first_message
                    FROM {EMBEDDING_TABLE} se
                    JOIN claude_sessions.sessions s ON se.session_id = s.session_id
                    LEFT JOIN claude_sessions.session_summaries ss ON se.session_id = ss.session_id
                    LEFT JOIN claude_sessions.first_messages fm ON se.session_id = fm.session_id
                    WHERE s.parent_session_id IS NULL
                    {time_filter}
                    ORDER BY se.embedding <=> %(vec)s::vector
                    LIMIT %(limit)s;
                """, params)
                rows = cur.fetchall()
        finally:
            conn.close()

        return [
            ScoredResult(
                session_id=r["session_id"],
                score=float(r["similarity"]),
                question_preview=clean_preview(r["first_message"] or ""),
                summary=r["summary"],
                project=derive_project(r["cwd"] or ""),
                date=r["start_time"],
                topics=_parse_topics(r["topics"]),
            )
            for r in rows
        ]


class FTSStrategy(SimilarityStrategy):
    """PostgreSQL full-text search + token overlap scoring."""

    def find_similar(self, query: str, limit: int, since_days: int | None) -> list[ScoredResult]:
        conn = get_conn()
        try:
            with conn.cursor(cursor_factory=psycopg2.extras.RealDictCursor) as cur:
                time_filter = ""
                if since_days:
                    time_filter = f"AND s.start_time >= NOW() - INTERVAL '{since_days} days'"

                # Try ts_rank first, fall back to ILIKE
                cur.execute(f"""
                    SELECT
                        s.session_id,
                        ts_rank(
                            to_tsvector('english', LEFT(COALESCE(fm.content, ''), 10000)),
                            plainto_tsquery('english', %(query)s)
                        ) AS rank,
                        ss.summary,
                        ss.user_requests,
                        ss.topics,
                        s.cwd,
                        s.start_time,
                        fm.content AS first_message
                    FROM claude_sessions.sessions s
                    LEFT JOIN claude_sessions.first_messages fm ON s.session_id = fm.session_id
                    LEFT JOIN claude_sessions.session_summaries ss ON s.session_id = ss.session_id
                    WHERE s.parent_session_id IS NULL
                    AND LENGTH(COALESCE(fm.content, '')) < 15000
                    AND (
                        to_tsvector('english', LEFT(COALESCE(fm.content, ''), 10000))
                            @@ plainto_tsquery('english', %(query)s)
                        OR LOWER(COALESCE(fm.content, '')) LIKE '%%' || LOWER(%(query)s) || '%%'
                        OR LOWER(COALESCE(ss.summary, '')) LIKE '%%' || LOWER(%(query)s) || '%%'
                    )
                    {time_filter}
                    ORDER BY rank DESC
                    LIMIT %(limit)s;
                """, {"query": query, "limit": limit})
                rows = cur.fetchall()
        finally:
            conn.close()

        # Application-level token overlap re-ranking
        query_tokens = set(query.lower().split())
        results = []
        for r in rows:
            text = (r["first_message"] or "") + " " + (r["summary"] or "")
            text_tokens = set(text.lower().split())
            overlap = len(query_tokens & text_tokens) / max(len(query_tokens), 1)
            score = float(r["rank"]) + overlap * 0.5

            results.append(ScoredResult(
                session_id=r["session_id"],
                score=score,
                question_preview=clean_preview(r["first_message"] or ""),
                summary=r["summary"],
                project=derive_project(r["cwd"] or ""),
                date=r["start_time"],
                topics=_parse_topics(r["topics"]),
            ))

        results.sort(key=lambda x: x.score, reverse=True)
        return results


def _parse_topics(topics) -> list[str]:
    if not topics:
        return []
    if isinstance(topics, list):
        return topics
    if isinstance(topics, str):
        # Could be JSON array or comma-separated
        topics = topics.strip()
        if topics.startswith("["):
            import json
            try:
                return json.loads(topics)
            except Exception:
                pass
        return [t.strip() for t in topics.split(",") if t.strip()]
    return []


