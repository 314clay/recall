class KnowledgeLoader:
    """Lazy loader — only fetches session content when explicitly requested."""

    def resolve_session_id(self, prefix: str) -> str | None:
        """Resolve a session ID prefix to a full session ID."""
        conn = get_conn()
        try:
            with conn.cursor() as cur:
                cur.execute("""
                    SELECT session_id FROM claude_sessions.sessions
                    WHERE session_id LIKE %s || '%%'
                    ORDER BY start_time DESC LIMIT 1;
                """, (prefix,))
                row = cur.fetchone()
                return row[0] if row else None
        finally:
            conn.close()

    def load(self, session_id: str, full: bool = False, tools: bool = False) -> SessionKnowledge | None:
        conn = get_conn()
        try:
            with conn.cursor(cursor_factory=psycopg2.extras.RealDictCursor) as cur:
                # Query 1: session_summaries
                cur.execute("""
                    SELECT summary, completed_work, user_requests, topics
                    FROM claude_sessions.session_summaries
                    WHERE session_id = %s;
                """, (session_id,))
                summary_row = cur.fetchone()

                # Query 2: First assistant message
                cur.execute("""
                    SELECT content FROM claude_sessions.messages
                    WHERE session_id = %s AND role = 'assistant'
                    ORDER BY created_at ASC LIMIT 1;
                """, (session_id,))
                first_answer_row = cur.fetchone()
                first_answer = ""
                if first_answer_row:
                    first_answer = first_answer_row["content"] or ""
                    if not full:
                        first_answer = first_answer[:2000]
                        if len(first_answer) == 2000:
                            first_answer += "\n…(truncated, use --full for complete)"

                # Query 3: All assistant messages (if --full)
                all_answers = None
                if full:
                    cur.execute("""
                        SELECT content FROM claude_sessions.messages
                        WHERE session_id = %s AND role = 'assistant'
                        ORDER BY created_at ASC;
                    """, (session_id,))
                    all_answers = [r["content"] for r in cur.fetchall() if r["content"]]

                # Query 4: Tool usages (if --tools)
                tool_counts = None
                if tools:
                    cur.execute("""
                        SELECT tu.tool_name, COUNT(*) as cnt
                        FROM claude_sessions.tool_usages tu
                        JOIN claude_sessions.messages m ON tu.message_id = m.id
                        WHERE m.session_id = %s
                        GROUP BY tu.tool_name
                        ORDER BY cnt DESC;
                    """, (session_id,))
                    tool_counts = {r["tool_name"]: r["cnt"] for r in cur.fetchall()}

        finally:
            conn.close()

        return SessionKnowledge(
            summary=summary_row["summary"] if summary_row else None,
            user_requests=summary_row["user_requests"] if summary_row else None,
            completed_work=summary_row["completed_work"] if summary_row else None,
            topics=_parse_topics(summary_row["topics"] if summary_row else None),
            first_answer=first_answer,
            tool_counts=tool_counts,
            all_answers=all_answers,
        )


# ─────────────────────────────────────────────────────────────────────
# Backfill
# ─────────────────────────────────────────────────────────────────────

def cmd_backfill(days: int | None = None):
    """Embed all sessions with summaries but no v2 embeddings."""
    conn = get_conn()
    ensure_table(conn)

    time_filter = ""
    if days:
        time_filter = f"AND s.start_time >= NOW() - INTERVAL '{days} days'"

    with conn.cursor(cursor_factory=psycopg2.extras.RealDictCursor) as cur:
        cur.execute(f"""
            SELECT ss.session_id, ss.summary, ss.user_requests
            FROM claude_sessions.session_summaries ss
            JOIN claude_sessions.sessions s ON ss.session_id = s.session_id
            LEFT JOIN {EMBEDDING_TABLE} se ON ss.session_id = se.session_id
            WHERE se.session_id IS NULL
            AND ss.summary IS NOT NULL
            {time_filter}
            ORDER BY s.start_time DESC;
        """)
        to_embed = cur.fetchall()
    conn.close()

    if not to_embed:
        print(f"{GREEN}All sessions already have v2 embeddings.{RESET}")
        return

    print(f"Found {BOLD}{len(to_embed)}{RESET} sessions to embed.")

    batch_size = 50
    total = len(to_embed)
    embedded = 0

    for i in range(0, total, batch_size):
        batch = to_embed[i:i + batch_size]
        texts = []
        for row in batch:
            text = (row["summary"] or "")
            if row["user_requests"]:
                text += "\n" + row["user_requests"]
            texts.append(text)

        try:
            embeddings = embed_texts(texts)
        except Exception as e:
            print(f"\n{BOLD}Error embedding batch {i // batch_size + 1}: {e}{RESET}")
            continue

        conn = get_conn()
        try:
            with conn.cursor() as cur:
                for row, emb in zip(batch, embeddings):
                    content_hash = hashlib.sha256(texts[batch.index(row)].encode()).hexdigest()[:16]
                    cur.execute(f"""
                        INSERT INTO {EMBEDDING_TABLE}
                            (session_id, embedding, content_hash, model)
                        VALUES (%(sid)s, %(emb)s::vector, %(hash)s, %(model)s)
                        ON CONFLICT (session_id) DO UPDATE SET
                            embedding = EXCLUDED.embedding,
                            content_hash = EXCLUDED.content_hash;
                    """, {
                        "sid": row["session_id"],
                        "emb": vec_str(emb),
                        "hash": content_hash,
                        "model": EMBEDDING_MODEL,
                    })
            conn.commit()
        finally:
            conn.close()

        embedded += len(batch)
        pct = embedded * 100 // total
        bar = "█" * (pct // 5) + "░" * (20 - pct // 5)
        print(f"\r  {bar} {embedded}/{total} ({pct}%)", end="", flush=True)

    print(f"\n{GREEN}Done. Embedded {embedded} sessions.{RESET}")

    # Create IVFFlat index if we now have enough rows
    conn = get_conn()
    try:
        ensure_index(conn)
    finally:
        conn.close()


