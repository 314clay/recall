def parse_since(value: str) -> int | None:
    """Parse --since value like '30d', '7d', '2w'."""
    if not value:
        return None
    m = re.match(r"^(\d+)([dwm])$", value.lower())
    if not m:
        print(f"Invalid --since format: {value} (use e.g. 30d, 2w, 3m)")
        sys.exit(1)
    n = int(m.group(1))
    unit = m.group(2)
    if unit == "d":
        return n
    elif unit == "w":
        return n * 7
    elif unit == "m":
        return n * 30
    return None


def _parse_bare_search():
    """Parse args when no subcommand is given (bare query mode)."""
    all_args = sys.argv[1:]
    query_parts = []
    limit = 10
    since = None
    strategy = "embedding"

    i = 0
    while i < len(all_args):
        if all_args[i] == "--limit" and i + 1 < len(all_args):
            limit = int(all_args[i + 1])
            i += 2
        elif all_args[i] == "--since" and i + 1 < len(all_args):
            since = all_args[i + 1]
            i += 2
        elif all_args[i] == "--strategy" and i + 1 < len(all_args):
            strategy = all_args[i + 1]
            i += 2
        elif all_args[i] in ("-h", "--help"):
            return None  # Let argparse handle it
        elif all_args[i].startswith("-"):
            print(f"Unknown option: {all_args[i]}")
            sys.exit(1)
        else:
            query_parts.append(all_args[i])
            i += 1

    if not query_parts:
        return None

    query = " ".join(query_parts)
    since_days = parse_since(since) if since else None

    if strategy == "fts":
        strat = FTSStrategy()
    else:
        strat = MultimodalEmbeddingStrategy()

    results = strat.find_similar(query, limit, since_days)
    display_results(results)
    return True


SUBCOMMANDS = {"search", "show", "backfill"}


def main():
    # Detect if the first positional arg is a known subcommand
    # If not, treat everything as a bare search query
    first_positional = None
    for arg in sys.argv[1:]:
        if not arg.startswith("-"):
            first_positional = arg
            break

    if first_positional not in SUBCOMMANDS:
        result = _parse_bare_search()
        if result:
            return
        # Fall through to argparse for --help etc.

    parser = argparse.ArgumentParser(
        description="Find similar prior Claude Code sessions",
        usage="qrecall [options] <query> | qrecall show <id> | qrecall backfill",
    )
    sub = parser.add_subparsers(dest="command")

    # Search (default)
    search_parser = sub.add_parser("search", help="Search for similar sessions")
    search_parser.add_argument("query", nargs="+", help="Search query")
    search_parser.add_argument("--limit", type=int, default=10)
    search_parser.add_argument("--since", type=str, default=None)
    search_parser.add_argument("--strategy", choices=["embedding", "fts"], default="embedding")

    # Show
    show_parser = sub.add_parser("show", help="Show session knowledge")
    show_parser.add_argument("session_id", help="Session ID or prefix")
    show_parser.add_argument("--full", action="store_true", help="Full assistant messages")
    show_parser.add_argument("--tools", action="store_true", help="Tool usage details")

    # Backfill
    backfill_parser = sub.add_parser("backfill", help="Embed sessions missing v2 embeddings")
    backfill_parser.add_argument("--days", type=int, default=None)

    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(1)

    if args.command == "search":
        query = " ".join(args.query)
        since_days = parse_since(args.since) if args.since else None

        if args.strategy == "fts":
            strat = FTSStrategy()
        else:
            strat = MultimodalEmbeddingStrategy()

        results = strat.find_similar(query, args.limit, since_days)
        display_results(results)

    elif args.command == "show":
        loader = KnowledgeLoader()
        full_id = loader.resolve_session_id(args.session_id)
        if not full_id:
            print(f"No session found matching prefix: {args.session_id}")
            sys.exit(1)

        knowledge = loader.load(full_id, full=args.full, tools=args.tools)
        if not knowledge:
            print(f"No data found for session: {full_id[:8]}…")
            sys.exit(1)

        display_knowledge(full_id, knowledge)

    elif args.command == "backfill":
        cmd_backfill(args.days)


if __name__ == "__main__":
    main()
