def display_results(results: list[ScoredResult]):
    if not results:
        print(f"{DIM}No matching sessions found.{RESET}")
        return

    for i, r in enumerate(results):
        # Score bar
        bar_width = 10
        filled = int(r.score * bar_width)
        bar = "█" * filled + "░" * (bar_width - filled)

        sid_short = r.session_id[:8]
        date_str = r.date.strftime("%Y-%m-%d") if r.date else "?"
        topics_str = " ".join(f"{MAGENTA}#{t}{RESET}" for t in r.topics[:3])

        print(f"  {DIM}{bar}{RESET} {GREEN}{r.score:.3f}{RESET}  "
              f"{CYAN}{sid_short}{RESET}  "
              f"{DIM}{date_str}{RESET}  "
              f"{YELLOW}{r.project}{RESET}")

        if r.question_preview:
            print(f"         {r.question_preview}")
        if r.summary:
            summary_short = r.summary[:120]
            if len(r.summary) > 120:
                summary_short += "…"
            print(f"         {DIM}{summary_short}{RESET}")
        if topics_str:
            print(f"         {topics_str}")
        print()


def display_knowledge(session_id: str, knowledge: SessionKnowledge):
    sid_short = session_id[:8]
    print(f"\n{BOLD}Session {CYAN}{sid_short}{RESET}{BOLD}…{RESET}\n")

    if knowledge.summary:
        print(f"{BOLD}Summary:{RESET}")
        print(f"  {knowledge.summary}\n")

    if knowledge.user_requests:
        print(f"{BOLD}User Requests:{RESET}")
        for line in knowledge.user_requests.strip().split("\n"):
            print(f"  {line}")
        print()

    if knowledge.completed_work:
        print(f"{BOLD}Completed Work:{RESET}")
        for line in knowledge.completed_work.strip().split("\n"):
            print(f"  {line}")
        print()

    if knowledge.topics:
        topics_str = " ".join(f"{MAGENTA}#{t}{RESET}" for t in knowledge.topics)
        print(f"{BOLD}Topics:{RESET} {topics_str}\n")

    if knowledge.first_answer:
        print(f"{BOLD}First Answer:{RESET}")
        print(f"  {knowledge.first_answer[:3000]}\n")

    if knowledge.all_answers:
        print(f"{BOLD}All Answers ({len(knowledge.all_answers)} messages):{RESET}")
        for i, ans in enumerate(knowledge.all_answers):
            print(f"\n  {DIM}--- message {i + 1} ---{RESET}")
            print(f"  {ans[:5000]}")
        print()

    if knowledge.tool_counts:
        print(f"{BOLD}Tool Usage:{RESET}")
        for tool, count in knowledge.tool_counts.items():
            print(f"  {YELLOW}{tool}{RESET}: {count}")
        print()


